# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# A fuller, zod-validated env reference lands in DIG-9.

# --- Database (Prisma) ---
# Local development via docker-compose (see docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prompt_library?schema=public"
#
# Production (hosted Postgres, e.g. Neon). Neon requires SSL and provides a
# pooled connection string for serverless. Example shape:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
