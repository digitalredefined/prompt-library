# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Access these in code via `@/lib/env` (zod-validated), not `process.env`.

# ---------------------------------------------------------------------------
# Database (Prisma) — REQUIRED
# ---------------------------------------------------------------------------
# Local development via docker-compose (see docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prompt_library?schema=public"
#
# Production (hosted Postgres, e.g. Neon). Neon requires SSL and provides a
# pooled connection string for serverless. Example shape:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth — required from M2 (DIG-11) onward
# ---------------------------------------------------------------------------
# Session encryption secret. Generate with: npx auth secret
AUTH_SECRET=""
# Google OAuth provider credentials (Google Cloud Console → OAuth client):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Anthropic Claude API — required from M6 (DIG-30) onward
# ---------------------------------------------------------------------------
# Server-side only. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Set to 1 to skip env validation (e.g. lint/typecheck in CI). Do not set in prod.
# SKIP_ENV_VALIDATION=1
